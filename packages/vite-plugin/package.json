    "url": "git+https://github.com/nudojs/nudo.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/nudojs/nudo/tree/main/packages/vite-plugin",
  "bugs": "https://github.com/nudojs/nudo/issues",
