{
  "name": "@nudojs/cli",
  "version": "0.2.0",
  "description": "CLI and evaluator API for the Nudo type inference engine",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "nudo",
    "type-inference",
    "javascript",
    "cli",
    "dts",
    "abstract-interpretation"
  ],
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./evaluator": "./src/evaluator-api.ts"
  },
  "bin": {
    "nudo": "src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nudojs/nudo.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/nudojs/nudo/tree/main/packages/cli",
  "bugs": "https://github.com/nudojs/nudo/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@nudojs/core": "workspace:*",
    "@nudojs/parser": "workspace:*"
  },
  "scripts": {
    "build": "tsup src/index.ts src/evaluator-api.ts --format esm --dts"
  }
}
