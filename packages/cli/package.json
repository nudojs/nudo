{
  "name": "@nudojs/cli",
  "version": "0.2.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./evaluator": "./src/evaluator-api.ts"
  },
  "bin": {
    "nudo": "src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nudojs/nudo.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@nudojs/core": "workspace:*",
    "@nudojs/parser": "workspace:*"
  },
  "scripts": {
    "build": "tsup src/index.ts src/evaluator-api.ts --format esm --dts"
  }
}
